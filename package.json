{
  "author": "onjmin",
  "license": "MIT",
  "name": "@onjmin/koe",
  "version": "1.0.2",
  "description": "UTAU concatenative synthesis engine optimized for browser / mobile via WebAssembly + AudioWorklet",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "koe-convert": "./dist/koe-convert.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/dev-server.ts",
    "watch": "tsup --watch",
    "convert": "tsx src/converter/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint2": "biome format src --write",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build",
    "patch": "pnpm version patch",
    "publish-dangerous-dont-use-this-command": "pnpm publish --access public"
  },
  "keywords": [
    "utau",
    "singing-synthesis",
    "audioworklet",
    "wasm"
  ],
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@hono/node-server": "2.0.5",
    "@types/node": "^22.0.0",
    "hono": "4.12.25",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "volta": {
    "node": "24.16.0",
    "pnpm": "11.7.0"
  }
}
